use "std/conv"
use "std/jule/build"
use "std/jule/log"
use "std/strings"

// Logger for compiler logs.
struct Logger{}

impl Logger {
	// Prints flag log.
	fn LogFlat(&l: *log::Log) {
		println(l.Text)
	}

	// Prints error log.
	fn LogError(&l: *log::Log) {
		print(AnsiRed)
		print("error: ")
		print(l.Text)
		AnsiEscape.Reset()

		if len(l.Path) != 0 {
			print("\n  --> ")
			print(l.Path)
		}
		if l.Row != 0 && l.Column != 0 {
			print(":")
			print(conv::Itoa(l.Row))
			print(":")
			print(conv::Itoa(l.Column))
		}
		if len(l.Line) != 0 {
			// For correct handling, trim leading and trailing space bytes.
			const Spaces = "\r\n\v\b\t "
			// Trim spaces of left first to know how many bytes were trimmed.
			// Because we need to shift the l.Column that much to point to the correct position.
			mut line := strings::TrimLeft(l.Line, Spaces)
			// Handle the difference after trim.
			trimmed := len(l.Line) - len(line)
			// Trim for right.
			line = strings::TrimRight(line, Spaces)
			// Size of tabs may vary across platforms/editors/IDEs.
			// Replace tabs with spaces for deterministic size.
			line = strings::ReplaceAll(line, "\t", " ")

			print("\n  ")
			row := conv::Itoa(l.Row)
			print(row)
			print(" | ")
			print(line)
			print("\n  ")
			print(strings::Repeat(" ", len(row)))
			print(" |")
			print(strings::Repeat(" ", l.Column-trimmed))
			print("^")
			if len(l.Suggestion) != 0 {
				print("\n  ")
				print(strings::Repeat(" ", len(row)))
				print(" | ")
				AnsiEscape.Print(AnsiBrightMagenta, "suggestion: ")
				print(l.Suggestion)
			}
		} else if len(l.Suggestion) != 0 {
			print("\n    | ")
			AnsiEscape.Print(AnsiBrightMagenta, "suggestion: ")
			print(l.Suggestion)
		}
		println("\n")
	}

	// Log.
	fn Log(&l: *log::Log) {
		match l.Kind {
		| log::Flat:
			Logger.LogFlat(l)
		| log::Error:
			Logger.LogError(l)
		}
	}

	// Prints all logs.
	fn PrintLogs(&logs: *[]log::Log) {
		for _, l in *logs {
			Logger.Log(&l)
		}
		print("=== ")
		errorCount := len(*logs)
		print(conv::Itoa(errorCount))
		if errorCount == 1 {
			print(" error")
		} else {
			print(" errors")
		}
		println(" generated ===")
	}
}
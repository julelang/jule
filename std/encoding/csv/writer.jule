use "std/bufio"
use "std/io"
use "std/strings"
use "std/unicode"
use "std/unicode/utf8"

// A Writer writes records using CSV encoding.
//
// As returned by new, a Writer writes records terminated by a
// newline and uses ',' as the field delimiter. The exported fields can be
// changed to customize the details before the first call to write or write_all.
//
// Comma is the field delimiter.
//
// If UseCRLF is true, the Writer ends each output line with \r\n instead of \n.
//
// The writes of individual records are buffered.
// After all data has been written, the client should call the
// Flush method to guarantee all data has been forwarded to
// the underlying io::Writer.
struct Writer {
	Comma:   rune // Field delimiter (set to ',' by new)
	UseCRLF: bool // True to use \r\n as the line terminator

	w: &bufio::Writer
}

impl Writer {
	// Returns new Writer instance that writes w.
	fn New(mut w: io::Writer): &Writer {
		ret &Writer{
			Comma: ',',
			w:     bufio::Writer.New(w),
		}
	}

	// Reports whether our field must be enclosed in quotes.
	// Fields with a comma, fields with a quote or newline, and
	// fields which start with a space must be enclosed in quotes.
	// We used to quote empty strings, but we do not anymore.
	// The two representations should be equivalent, but Postgres distinguishes
	// quoted vs non-quoted empty string during database imports, and it has
	// an option to force the quoted behavior for non-quoted CSV but it has
	// no option to force the non-quoted behavior for quoted CSV, making
	// CSV with quoted empty strings strictly less useful.
	// Not quoting the empty string also makes this package match the behavior
	// of Microsoft Excel and Google Drive.
	// For Postgres, quote the data terminating string `\.`.
	fn fieldNeedsQuotes(*self, field: str): bool {
		if len(field) == 0 {
			ret false
		}
		if field == `\.` {
			ret true
		}
		if self.Comma < utf8::RuneSelf {
			mut i := 0
			for i < len(field); i++ {
				c := field[i]
				if c == '\n' || c == '\r' || c == '"' || c == byte(self.Comma) {
					ret true
				}
			}
		} else if strings::ContainsRune(field, self.Comma) ||
			strings::ContainsAny(field, "\"\r\n") {
			ret true
		}
		r1, _ := utf8::DecodeRuneStr(field)
		ret unicode::IsSpace(r1)
	}

	// Writes a single CSV record along with any necessary quoting.
	// A record is a slice of strings with each string being one field.
	async fn Write(mut *self, record: []str)! {
		if !validDelim(self.Comma) {
			throw errInvalidDelim
		}
		for (n, mut field) in record {
			if n > 0 {
				self.w.WriteRune(self.Comma).await?
			}

			// If we don't have to have a quoted field then just
			// write out the field and continue to the next field.
			if !self.fieldNeedsQuotes(field) {
				self.w.WriteStr(field).await?
				continue
			}

			self.w.WriteByte('"').await?

			for len(field) > 0 {
				// Search for special characters.
				mut i := strings::IndexAny(field, "\"\r\n")
				if i < 0 {
					i = len(field)
				}

				// Copy verbatim everything before the special character.
				self.w.WriteStr(field[:i]).await?
				field = field[i:]

				// Encode the special character.
				if len(field) > 0 {
					match field[0] {
					| '"':
						self.w.WriteStr(`""`).await?
					| '\r':
						if !self.UseCRLF {
							self.w.WriteByte('\r').await?
						}
					| '\n':
						if self.UseCRLF {
							self.w.WriteStr("\r\n").await?
						} else {
							self.w.WriteByte('\n').await?
						}
					}
					field = field[1:]
				}
			}

			self.w.WriteByte('"').await?
		}
		if self.UseCRLF {
			self.w.WriteStr("\r\n").await?
		} else {
			self.w.WriteByte('\n').await?
		}
	}

	// Writes any buffered data to the underlying io::Writer.
	async fn Flush(mut *self)! {
		self.w.Flush().await?
	}

	// Writes multiple CSV records using [Writer.Write].
	async fn WriteAll(mut *self, records: [][]str)! {
		for _, record in records {
			self.Write(record).await?
		}
		self.w.Flush().await?
	}
}
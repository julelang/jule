// Reports whether data is a valid JSON encoding.
fn Valid(data: []byte): bool {
	let mut scan: scanner
	scan.init()
	scan.reset()
	for _, c in data {
		scan.bytes++
		if scan.step(&scan, c) == scanError {
			ret false
		}
	}
	ret scan.eof() != scanError
}
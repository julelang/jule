use "std/conv"
use "std/io"
use "std/strings"
use "std/testing"

let encodeDecodeMap = [
	// RFC 3548 examples.
	[[]byte("\x14\xfb\x9c\x03\xd9\x7e"), []byte("FPucA9l+")],
	[[]byte("\x14\xfb\x9c\x03\xd9"), []byte("FPucA9k=")],
	[[]byte("\x14\xfb\x9c\x03"), []byte("FPucAw==")],

	// RFC 4648 examples.
	[[]byte(""), []byte("")],
	[[]byte("f"), []byte("Zg==")],
	[[]byte("fo"), []byte("Zm8=")],
	[[]byte("foo"), []byte("Zm9v")],
	[[]byte("foob"), []byte("Zm9vYg==")],
	[[]byte("fooba"), []byte("Zm9vYmE=")],
	[[]byte("foobar"), []byte("Zm9vYmFy")],

	// Wikipedia examples.
	[[]byte("sure."), []byte("c3VyZS4=")],
	[[]byte("sure"), []byte("c3VyZQ==")],
	[[]byte("sur"), []byte("c3Vy")],
	[[]byte("su"), []byte("c3U=")],
	[[]byte("leasure."), []byte("bGVhc3VyZS4=")],
	[[]byte("easure."), []byte("ZWFzdXJlLg==")],
	[[]byte("asure."), []byte("YXN1cmUu")],
]

let bigtest = [
	"Twas brillig, and the slithy toves",
	"VHdhcyBicmlsbGlnLCBhbmQgdGhlIHNsaXRoeSB0b3Zlcw==",
]

#test
fn testStdEncodingEncode(t: &testing::T) {
	for _, case in encodeDecodeMap {
		r := StdEncoding.AppendEncode(nil, case[0])
		d := case[1]
		if !bytesequal(r, d) {
			t.Fail()
			continue
		}
	}
}

#test
fn testStdEncodingDecode(t: &testing::T) {
	for _, case in encodeDecodeMap {
		r := StdEncoding.AppendDecode(nil, case[1])!
		d := case[0]
		if !bytesequal(r, d) {
			t.Fail()
			continue
		}
	}
}

#test
async fn testStdEncoder(t: &testing::T) {
	for _, case in encodeDecodeMap {
		mut sb := new(strings::Builder)
		mut enc := NewEncoder(StdEncoding, sb.Async())
		enc.Write(case[0]).await!
		enc.Close().await!
		r := unsafe { sb.Buf() }
		d := case[1]
		if !bytesequal(r, d) {
			t.Fail()
			continue
		}
	}
}

#test
async fn testEncoderBuffering(t: &testing::T) {
	input := []byte(bigtest[0])
	mut bs := 1
	for bs <= 12; bs++ {
		mut bb := new(strings::Builder)
		mut encoder := NewEncoder(StdEncoding, bb.Async())
		mut pos := 0
		for pos < len(input); pos += bs {
			mut end := pos + bs
			if end > len(input) {
				end = len(input)
			}
			n := encoder.Write(input[pos:end]).await else {
				t.Errorf("Write({}) gave error {}, want nil", input[pos:end], error)
				continue
			}
			if n != end-pos {
				t.Errorf("Write({}) gave length {}, want {}", input[pos:end], n, end-pos)
				continue
			}
		}
		encoder.Close().await else {
			t.Errorf("Close gave error {}, want nil", error)
			continue
		}
		r := unsafe { bb.Buf() }
		if !bytesequal(r, []byte(bigtest[1])) {
			t.Errorf("Encoding/{} of {} = {}, want {}", bs, bigtest[1], bb.Str(), bigtest[0])
			continue
		}
	}
}

#test
async fn testStdDecoder(t: &testing::T) {
	for _, case in encodeDecodeMap {
		mut sr := strings::Reader.New(str(case[1]))
		mut dec := NewDecoder(StdEncoding, sr.Async())
		mut buf := make([]byte, StdEncoding.DecodedLen(len(case[1])))
		n := dec.Read(buf).await else {
			if error != io::EOF {
				t.Errorf("unexpected error {}", error)
				continue
			}
			use 0
		}
		r := buf[:n]
		d := case[0]
		if !bytesequal(r, d) {
			t.Fail()
			continue
		}
	}
}

#test
async fn testDecoderBuffering(t: &testing::T) {
	mut bs := 1
	for bs <= 12; bs++ {
		mut decoder := NewDecoder(StdEncoding, strings::Reader.New(bigtest[1]).Async())
		mut buf := make([]byte, len(bigtest[0])+12)
		let mut total: int
		let mut n: int
		let mut err: any
		for total < len(bigtest[0]) && err == nil {
			n = decoder.Read(buf[total : total+bs]).await else {
				if error == io::EOF {
					break
				}
				err = error
				break
			}
			total += n
		}
		if err != nil {
			t.Errorf("Read from {} at pos {} = {}, unexpected error {}", bigtest[1], total, n, err)
		}
		if !bytesequal([]byte(bigtest[0]), buf[0:total]) {
			t.Errorf("Decoding/{} of {} = {}, want {}", bs, bigtest[1], str(buf[0:total]), bigtest[0])
		}
	}
}

struct decodeCorruptTest {
	input:  str
	offset: int // -1 means no corruption.
}

let decodeCorruptTests: []decodeCorruptTest = [
	{"", -1},
	{"\n", -1},
	{"AAA=\n", -1},
	{"AAAA\n", -1},
	{"!!!!", 0},
	{"====", 0},
	{"x===", 1},
	{"=AAA", 0},
	{"A=AA", 1},
	{"AA=A", 2},
	{"AA==A", 4},
	{"AAA=AAAA", 4},
	{"AAAAA", 4},
	{"AAAAAA", 4},
	{"A=", 1},
	{"A==", 1},
	{"AA=", 3},
	{"AA==", -1},
	{"AAA=", -1},
	{"AAAA", -1},
	{"AAAAAA=", 7},
	{"YWJjZA=====", 8},
	{"A!\n", 1},
	{"A=\n", 1},
]

#test
fn testDecodeCorrupt(t: &testing::T) {
	for i, test in decodeCorruptTests {
		StdEncoding.AppendDecode(nil, []byte(test.input)) else {
			if test.offset == -1 {
				t.Errorf("#{} expected no error, found error", i)
				continue
			}
			match type error {
			| CorruptInputError:
				offset := int(error.(CorruptInputError))
				if test.offset != offset {
					t.Errorf("#{} decoder points to a different location for corruption", i)
				}
			|:
				t.Errorf("#{} decoder failed to detect corruption", i)
			}
			continue
		}
		if test.offset != -1 {
			t.Errorf("#{} expected error, found no error", i)
			continue
		}
	}
}

struct codedLenTest {
	enc:  &Encoding
	n:    int
	want: i64
}

let mut encodedLenTests: []codedLenTest = [
	{RawStdEncoding, 0, 0},
	{RawStdEncoding, 1, 2},
	{RawStdEncoding, 2, 3},
	{RawStdEncoding, 3, 4},
	{RawStdEncoding, 7, 10},
	{StdEncoding, 0, 0},
	{StdEncoding, 1, 4},
	{StdEncoding, 2, 4},
	{StdEncoding, 3, 4},
	{StdEncoding, 4, 8},
	{StdEncoding, 7, 12},
]

#test
fn testEncodedLen(t: &testing::T) {
	// check overflow
	match conv::IntSize {
	| 32:
		encodedLenTests = append(encodedLenTests, {RawStdEncoding, (int.Max-5)/8+1, 357913942})
		encodedLenTests = append(encodedLenTests, {RawStdEncoding, int.Max/4*3+2, int.Max})
	| 64:
		encodedLenTests = append(encodedLenTests, {RawStdEncoding, (int.Max-5)/8+1, 1537228672809129302})
		encodedLenTests = append(encodedLenTests, {RawStdEncoding, int.Max/4*3+2, int.Max})
	}
	for _, test in encodedLenTests {
		got := test.enc.EncodedLen(test.n)
		if i64(got) != test.want {
			t.Errorf("EncodedLen({}): got {}, want {}", test.n, got, test.want)
		}
	}
}

let mut decodedLenTests: []codedLenTest = [
	{RawStdEncoding, 0, 0},
	{RawStdEncoding, 2, 1},
	{RawStdEncoding, 3, 2},
	{RawStdEncoding, 4, 3},
	{RawStdEncoding, 10, 7},
	{StdEncoding, 0, 0},
	{StdEncoding, 4, 3},
	{StdEncoding, 8, 6},
]

#test
fn testDecodedLen(t: &testing::T) {
	// check overflow
	match conv::IntSize {
	| 32:
		decodedLenTests = append(decodedLenTests, {RawStdEncoding, int.Max/6+1, 268435456})
		decodedLenTests = append(decodedLenTests, {RawStdEncoding, int.Max, 1610612735})
	| 64:
		decodedLenTests = append(decodedLenTests, {RawStdEncoding, int.Max/6+1, 1152921504606846976})
		decodedLenTests = append(decodedLenTests, {RawStdEncoding, int.Max, 6917529027641081855})
	}
	for _, test in decodedLenTests {
		got := test.enc.DecodedLen(test.n)
		if i64(got) != test.want {
			t.Errorf("DecodedLen({}): got {}, want {}", test.n, got, test.want)
		}
	}
}

#test
async fn testBig(t: &testing::T) {
	n := 3*1000 + 1
	mut raw := make([]byte, n)
	const alpha = "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
	mut i := 0
	for i < n; i++ {
		raw[i] = alpha[i%len(alpha)]
	}
	mut sb := new(strings::Builder)
	mut w := NewEncoder(StdEncoding, sb.Async())
	nn := w.Write(raw).await else {
		t.Errorf("Encoder.Write(raw) error = {} want nil", error)
		ret
	}
	if nn != n {
		t.Errorf("Encoder.Write(raw) = {} want {}", nn, n)
		ret
	}
	w.Close().await else {
		t.Errorf("Encoder.Close() = {} want nil", error)
		ret
	}
	mut sr := strings::Reader.New(sb.Str())
	decoded := io::ReadAll(NewDecoder(StdEncoding, sr.Async())).await else {
		t.Errorf("io::ReadAll(NewDecoder(...)): {}", error)
		ret
	}

	if !bytesequal(raw, decoded) {
		i = 0
		for i < len(decoded) && i < len(raw); i++ {
			if decoded[i] != raw[i] {
				break
			}
		}
		t.Errorf("Decode(Encode({}-byte string)) failed at offset {}", n, i)
	}
}

#test
fn testNewLineCharacters(t: &testing::T) {
	// Each of these should decode to the string "sure", without errors.
	const expected = "sure"
	examples := [
		"c3VyZQ==",
		"c3VyZQ==\r",
		"c3VyZQ==\n",
		"c3VyZQ==\r\n",
		"c3VyZ\r\nQ==",
		"c3V\ryZ\nQ==",
		"c3V\nyZ\rQ==",
		"c3VyZ\nQ==",
		"c3VyZQ\n==",
		"c3VyZQ=\n=",
		"c3VyZQ=\r\n\r\n=",
	]
	for _, e in examples {
		buf := StdEncoding.DecodeStr(e) else {
			t.Errorf("Decode({}) failed: {}", e, error)
			continue
		}
		s := str(buf)
		if s != expected {
			t.Errorf("Decode({}) = {}, want {}", e, s, expected)
		}
	}
}

#test
async fn testDecoderGoIssue4779(t: &testing::T) {
	encoded := `CP/EAT8AAAEF
AQEBAQEBAAAAAAAAAAMAAQIEBQYHCAkKCwEAAQUBAQEBAQEAAAAAAAAAAQACAwQFBgcICQoLEAAB
BAEDAgQCBQcGCAUDDDMBAAIRAwQhEjEFQVFhEyJxgTIGFJGhsUIjJBVSwWIzNHKC0UMHJZJT8OHx
Y3M1FqKygyZEk1RkRcKjdDYX0lXiZfKzhMPTdePzRieUpIW0lcTU5PSltcXV5fVWZnaGlqa2xtbm
9jdHV2d3h5ent8fX5/cRAAICAQIEBAMEBQYHBwYFNQEAAhEDITESBEFRYXEiEwUygZEUobFCI8FS
0fAzJGLhcoKSQ1MVY3M08SUGFqKygwcmNcLSRJNUoxdkRVU2dGXi8rOEw9N14/NGlKSFtJXE1OT0
pbXF1eX1VmZ2hpamtsbW5vYnN0dXZ3eHl6e3x//aAAwDAQACEQMRAD8A9VSSSSUpJJJJSkkkJ+Tj
1kiy1jCJJDnAcCTykpKkuQ6p/jN6FgmxlNduXawwAzaGH+V6jn/R/wCt71zdn+N/qL3kVYFNYB4N
ji6PDVjWpKp9TSXnvTf8bFNjg3qOEa2n6VlLpj/rT/pf567DpX1i6L1hs9Py67X8mqdtg/rUWbbf
+gkp0kkkklKSSSSUpJJJJT//0PVUkkklKVLq3WMDpGI7KzrNjADtYNXvI/Mqr/Pd/q9W3vaxjnvM
NaCXE9gNSvGPrf8AWS3qmba5jjsJhoB0DAf0NDf6sevf+/lf8Hj0JJATfWT6/dV6oXU1uOLQeKKn
EQP+Hubtfe/+R7Mf/g7f5xcocp++Z11JMCJPgFBxOg7/AOuqDx8I/ikpkXkmSdU8mJIJA/O8EMAy
j+mSARB/17pKVXYWHXjsj7yIex0PadzXMO1zT5KHoNA3HT8ietoGhgjsfA+CSnvvqh/jJtqsrwOv
2b6NGNzXfTYexzJ+nU7/ALkf4P8Awv6P9KvTQQ4AgyDqCF85Pho3CTB7eHwXoH+LT65uZbX9X+o2
bqbPb06551Y4
`
	encodedShort := strings::ReplaceAll(encoded, "\n", "")

	mut dec := NewDecoder(StdEncoding, strings::Reader.New(encoded).Async())
	res1 := io::ReadAll(dec).await else {
		t.Errorf("ReadAll failed: {}", error)
		ret
	}

	dec = NewDecoder(StdEncoding, strings::Reader.New(encodedShort).Async())
	res2 := io::ReadAll(dec).await else {
		t.Errorf("ReadAll failed: {}", error)
		ret
	}

	if !bytesequal(res1, res2) {
		t.Errorf("Decoded results not equal")
		ret
	}
}

#test
fn testDecoderGoIssue7733(t: &testing::T) {
	StdEncoding.DecodeStr("YWJjZA=====") else {
		want := CorruptInputError(8)
		if want != error {
			t.Errorf("Error = {}; want CorruptInputError(8)", error)
		}
		ret
	}
	t.Errorf("DecodeStr = nil; want CorruptInputError(8)")
}

#test
fn testDecoderGoIssue15656(t: &testing::T) {
	let mut err: any
	StdEncoding.Clone().Strict().DecodeStr("WvLTlMrX9NpYDQlEIFlnDB==") else {
		err = error
	}
	want := CorruptInputError(22)
	if want != err {
		t.Errorf("Error = {}; want CorruptInputError(22)", err)
	}
	StdEncoding.Clone().Strict().DecodeStr("WvLTlMrX9NpYDQlEIFlnDA==") else {
		t.Errorf("Error = {}; want nil", error)
	}
	StdEncoding.DecodeStr("WvLTlMrX9NpYDQlEIFlnDB==") else {
		t.Errorf("Error = {}; want nil", error)
	}
}

fn bytesequal(a: []byte, b: []byte): bool {
	if len(a) != len(b) {
		ret false
	}
	for i in a {
		if a[i] != b[i] {
			ret false
		}
	}
	ret true
}
fn single(): int {
	ret 90
}

fn singleAny(): any {
	ret single()
}

fn multi(): (int, int) {
	ret 90, 12
}

fn multiAny(): (any, any) {
	ret multi()
}

fn fallibleSingle()!: int {
	throw "foo"
}

fn singleAny1(): any {
	ret fallibleSingle()!
}

fn singleAny2(): any {
	ret fallibleSingle() else {
		use 90
	}
}

fn fallibleMulti()!: (int, int) {
	throw "foo"
}

fn multiAny1(): (any, any) {
	ret fallibleMulti()!
}

fn multiAny2(): (any, any) {
	ret fallibleMulti() else {
		use 90, 12
	}
}

fn init() {
	{
		fallibleSingle() else {
			goto ES
		}
		panic("fallibleSingle returns without error, expected error")
	ES:
	}
	{
		fallibleMulti() else {
			goto EM
		}
		panic("fallibleMulti returns without error, expected error")
	EM:
	}
	{
		x := singleAny()
		if x != 90 {
			panic("x != 90")
		}
	}
	{
		x, y := multiAny()
		if x != 90 {
			panic("x != 90")
		}
		if y != 12 {
			panic("x != 12")
		}
	}
	{
		x := singleAny2()
		if x != 90 {
			panic("x != 90")
		}
	}
	{
		x, y := multiAny2()
		if x != 90 {
			panic("x != 90")
		}
		if y != 12 {
			panic("x != 12")
		}
	}
}